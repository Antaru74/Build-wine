# name: Package Wine NTSYNC for Termux

on:
  workflow_dispatch:
    inputs:
      wine_version:
        description: 'Wine version (e.g., 11.2)'
        required: true
        default: '11.2'

jobs:
  package-wine-ntsync:
    runs-on: ubuntu-22.04
    steps:
      - name: Download Wine NTSYNC binary from Kron4ek
        run: |
          VERSION=${{ github.event.inputs.wine_version }}
          FILE="wine-${VERSION}-staging-tkg-amd64-wow64.tar.xz"
          URL="https://github.com/Kron4ek/Wine-Builds/releases/download/${VERSION}/${FILE}"
          
          curl -L -o wine-ntsync.tar.xz "$URL"
          tar -xf wine-ntsync.tar.xz
          
          # Hasil extract: direktori seperti wine-11.2-staging-tkg-amd64-wow64/
          
      - name: Create .deb package structure
        run: |
          PKG_NAME="wine-ntsync"
          PKG_VERSION="${{ github.event.inputs.wine_version }}"
          DEB_ROOT="wine-ntsync-deb"
          
          # Struktur untuk Termux (prefix /data/data/com.termux/files/usr)
          mkdir -p $DEB_ROOT/data/data/com.termux/files/usr/libexec/wine-ntsync
          mkdir -p $DEB_ROOT/DEBIAN
          
          # Copy binary Wine
          WINE_DIR=$(ls -d wine-*staging-tkg-amd64-wow64 | head -1)
          cp -r $WINE_DIR/* $DEB_ROOT/data/data/com.termux/files/usr/libexec/wine-ntsync/
          
          # Buat wrapper script di $PREFIX/bin
          mkdir -p $DEB_ROOT/data/data/com.termux/files/usr/bin
          cat > $DEB_ROOT/data/data/com.termux/files/usr/bin/wine << 'EOF'
          #!/data/data/com.termux/files/usr/bin/bash
          export WINEPREFIX="${WINEPREFIX:-$HOME/.wine}"
          exec /data/data/com.termux/files/usr/libexec/wine-ntsync/bin/wine "$@"
          EOF
          chmod +x $DEB_ROOT/data/data/com.termux/files/usr/bin/wine
          
          # Buat control file
          cat > $DEB_ROOT/DEBIAN/control << EOF
          Package: wine-ntsync
          Version: ${PKG_VERSION}-1
          Architecture: aarch64
          Maintainer: Your Name <email@example.com>
          Depends: box64, termux-exec
          Description: Wine with NTSYNC support for Termux (aarch64)
           Pre-built binary from Kron4ek/Wine-Builds (staging-tkg-amd64-wow64)
           Runs via Box64 emulation. Requires kernel 6.14+ with ntsync module.
          EOF
          
      - name: Build .deb package
        run: |
          dpkg-deb --build wine-ntsync-deb
          mv wine-ntsync-deb.deb wine-ntsync-${{ github.event.inputs.wine_version }}-aarch64.deb
          
      - name: Upload .deb
        uses: actions/upload-artifact@v4
        with:
          name: wine-ntsync-deb
          path: "*.deb"-wine
